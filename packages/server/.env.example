# --- Runtime mode ----------------------------------------------------------
# "prototype" enables permissive CORS, generous rate limits, and a single
# shared API key. "production" enforces per-tenant CORS, per-tenant rate
# limits, and per-tenant hashed API keys. Anything else should throw at boot.
APP_MODE=prototype

# --- Server ----------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database --------------------------------------------------------------
# Local dev: postgres://postgres:postgres@localhost:5433/app
# Production: Supabase pooled connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5433/app

# --- Auth ------------------------------------------------------------------
# Prototype only: a single shared API key used by the auth middleware.
# In production, per-tenant hashed keys from the api_keys table replace this.
SHARED_API_KEY=replace-me-with-a-long-random-string

# --- Error tracking --------------------------------------------------------
# Optional. Unset in prototype so error tracker runs as a no-op; set in
# production to activate Sentry.
# SENTRY_DSN=

# --- Per-tenant secrets (referenced by tenants/*.json) ---------------------
# Each tenant file references env vars of the form ${TEAM_<NAME>_GH_TOKEN}.
# Add the matching vars here. Example:
# TEAM_ALPHA_GH_TOKEN=
# TEAM_ALPHA_ISSUE_TOKEN=
# TEAM_ALPHA_LLM_API_KEY=
