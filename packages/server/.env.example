# --- Runtime mode ----------------------------------------------------------
# "prototype" enables permissive CORS, generous rate limits, and a single
# shared API key. "production" enforces per-tenant CORS, per-tenant rate
# limits, and per-tenant hashed API keys. Anything else should throw at boot.
APP_MODE=prototype

# --- Server ----------------------------------------------------------------
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database --------------------------------------------------------------
# Local dev: postgres://postgres:postgres@localhost:5433/app
# Production: Supabase pooled connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5433/app
