{
  "name": "advanced-troubleshooter",
  "version": "0.0.0",
  "private": true,
  "description": "Codebase-aware support assistant — monorepo root",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "eslint packages",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "migrate": "npm run migrate --workspace @advanced-troubleshooter/server"
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
